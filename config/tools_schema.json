  {
    "type": "function",
    "function": {
      "name": "execute_kali_command",
      "description": "在 Kali Linux 本地执行渗透测试相关的系统命令并返回完整输出。支持的工具包括：nmap, wapiti, nikto, sqlmap, hydra, gobuster, dirsearch, searchsploit, curl, whoami, uname, cat, ls, ping, netstat 等。执行前建议先用 which 检查工具是否存在。",
      "parameters": {
        "type": "object",
        "properties": {
          "command": {
            "type": "string",
            "description": "要执行的命令（含参数），例如 'nmap -sC -sV 10.0.0.1'"
          }
        },
        "required": [
          "command"
        ]
      }
    }
  },
