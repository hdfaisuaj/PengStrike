{
  "llm": {
    "base_url": "https://openrouter.ai/api/v1",
    "api_key": "YOUR_API_KEY_HERE",
    "model": "openrouter/free",
    "temperature": 0.1,
    "max_tokens": 2048,
    "timeout": 60,
    "max_retries": 3,
    "fallback_base_url": "",
    "fallback_api_key": "",
    "fallback_model": "",
    "fallback_provider": "openai"
  },
  "security": {
    "ast_enabled": true,
    "anomaly_detection_enabled": true
  },
  "system": {
    "command_timeout": 300,
    "log_level": "INFO",
    "llm_max_tokens": 4096,
    "context_max_tokens": 4096,
    "context_reserve_recent": 4,
    "dangerous_interrupt": true,
    "cors_allowed_origins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  },
  "backend": {
    "host": "127.0.0.1",
    "port": 8000,
    "frontend_port": 5173
  },
  "mcp": {
    "enabled": false,
    "host": "127.0.0.1",
    "port": 8911
  },
  "report": {
    "output_dir": null
  },
  "database": {
    "url": null
  }
}
